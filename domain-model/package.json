{
  "name": "evolimo-domain-model",
  "version": "0.1.0",
  "description": "TypeScript DSL for defining evolution simulation physics and genetics",
  "type": "module",
  "engines": {
    "node": ">=24.10"
  },
  "scripts": {
    "build": "tsx src/compiler.ts",
    "fmt": "biome format --write .",
    "check-types": "tsc --noEmit",
    "lint": "biome lint .",
    "check": "npm run check-types && npm run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.10.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
